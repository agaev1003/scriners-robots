# Tinkoff Invest API token (get from https://www.tinkoff.ru/invest/settings/)
TKF_TOKEN=t.your-token-here

# Account ID (run: node -e "import('./tinkoff.js').then(t=>t.getAccounts('YOUR_TOKEN').then(a=>console.log(a)))")
TKF_ACCOUNT_ID=

# Dry run mode — true = no real orders, false = live trading
DRY_RUN=true

# Web panel port (0 = disabled)
PORT=8080
